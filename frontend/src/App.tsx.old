import { useEffect, useMemo, useRef, useState } from 'react'
import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query'
import {
  createCliente,
  createMascota,
  createMedicamento,
  deleteCliente,
  deleteMascota,
  deleteMedicamento,
  getClientes,
  getMascotas,
  getMedicamentos,
  updateCliente,
  updateMascota,
  updateMedicamento,
} from './api/domain'
import { getAuditoriaMedicamentosClientes } from './api/reportes'
import { DataTable } from './components/table/DataTable'
import type { AuditoriaDetalle } from './types/reportes'

function App() {
  const queryClient = useQueryClient()
  const clienteUpdateRef = useRef<HTMLElement | null>(null)
  const medicamentoUpdateRef = useRef<HTMLElement | null>(null)
  const mascotaUpdateRef = useRef<HTMLElement | null>(null)
  const [clienteForm, setClienteForm] = useState({
    cedula: '',
    nombres: '',
    apellidos: '',
    direccion: '',
    telefono: '',
  })
  const [medicamentoForm, setMedicamentoForm] = useState({
    nombre: '',
    descripcion: '',
    dosis: '',
  })
  const [mascotaForm, setMascotaForm] = useState({
    nombre: '',
    raza: '',
    edad: '',
    peso: '',
    medicamentoId: '',
    clienteId: '',
  })
  const [clienteUpdateForm, setClienteUpdateForm] = useState({
    cedula: '',
    nombres: '',
    apellidos: '',
    direccion: '',
    telefono: '',
  })
  const [medicamentoUpdateForm, setMedicamentoUpdateForm] = useState({
    id: '',
    nombre: '',
    descripcion: '',
    dosis: '',
  })
  const [mascotaUpdateForm, setMascotaUpdateForm] = useState({
    id: '',
    nombre: '',
    raza: '',
    edad: '',
    peso: '',
    medicamentoId: '',
    clienteId: '',
  })
  const [highlightedSection, setHighlightedSection] = useState<
    'cliente' | 'medicamento' | 'mascota' | null
  >(null)
  const [toastMessage, setToastMessage] = useState<string | null>(null)

  const {
    data,
    isLoading,
    isError,
    error,
    refetch: refetchAuditoria,
    isFetching,
  } = useQuery({
    queryKey: ['auditoria-medicamentos-clientes'],
    queryFn: getAuditoriaMedicamentosClientes,
  })
  const { data: clientes = [] } = useQuery({
    queryKey: ['clientes'],
    queryFn: getClientes,
  })
  const { data: medicamentos = [] } = useQuery({
    queryKey: ['medicamentos'],
    queryFn: getMedicamentos,
  })
  const { data: mascotas = [] } = useQuery({
    queryKey: ['mascotas'],
    queryFn: getMascotas,
  })

  const refreshAll = async () => {
    await queryClient.invalidateQueries({ queryKey: ['clientes'] })
    await queryClient.invalidateQueries({ queryKey: ['medicamentos'] })
    await queryClient.invalidateQueries({ queryKey: ['mascotas'] })
    await queryClient.invalidateQueries({
      queryKey: ['auditoria-medicamentos-clientes'],
    })
  }

  const scrollToUpdateSection = (section: 'cliente' | 'medicamento' | 'mascota') => {
    const refs = {
      cliente: clienteUpdateRef,
      medicamento: medicamentoUpdateRef,
      mascota: mascotaUpdateRef,
    }

    refs[section].current?.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  useEffect(() => {
    if (!highlightedSection) {
      return
    }

    const timer = setTimeout(() => {
      setHighlightedSection(null)
    }, 2000)

    return () => clearTimeout(timer)
  }, [highlightedSection])

  useEffect(() => {
    if (!toastMessage) {
      return
    }

    const timer = setTimeout(() => {
      setToastMessage(null)
    }, 2200)

    return () => clearTimeout(timer)
  }, [toastMessage])

  const createClienteMutation = useMutation({
    mutationFn: createCliente,
    onSuccess: async () => {
      setClienteForm({
        cedula: '',
        nombres: '',
        apellidos: '',
        direccion: '',
        telefono: '',
      })
      await refreshAll()
    },
  })
  const updateClienteMutation = useMutation({
    mutationFn: (payload: typeof clienteUpdateForm) =>
      updateCliente(payload.cedula, {
        nombres: payload.nombres,
        apellidos: payload.apellidos,
        direccion: payload.direccion,
        telefono: payload.telefono,
      }),
    onSuccess: async () => {
      await refreshAll()
    },
  })
  const deleteClienteMutation = useMutation({
    mutationFn: deleteCliente,
    onSuccess: async () => {
      await refreshAll()
    },
  })

  const createMedicamentoMutation = useMutation({
    mutationFn: createMedicamento,
    onSuccess: async () => {
      setMedicamentoForm({
        nombre: '',
        descripcion: '',
        dosis: '',
      })
      await refreshAll()
    },
  })
  const updateMedicamentoMutation = useMutation({
    mutationFn: (payload: typeof medicamentoUpdateForm) =>
      updateMedicamento(Number(payload.id), {
        nombre: payload.nombre,
        descripcion: payload.descripcion,
        dosis: payload.dosis,
      }),
    onSuccess: async () => {
      await refreshAll()
    },
  })
  const deleteMedicamentoMutation = useMutation({
    mutationFn: deleteMedicamento,
    onSuccess: async () => {
      await refreshAll()
    },
  })

  const createMascotaMutation = useMutation({
    mutationFn: createMascota,
    onSuccess: async () => {
      setMascotaForm({
        nombre: '',
        raza: '',
        edad: '',
        peso: '',
        medicamentoId: '',
        clienteId: '',
      })
      await refreshAll()
    },
  })
  const updateMascotaMutation = useMutation({
    mutationFn: (payload: typeof mascotaUpdateForm) =>
      updateMascota(payload.id, {
        nombre: payload.nombre,
        raza: payload.raza,
        edad: Number(payload.edad),
        peso: Number(payload.peso),
        medicamentoId: Number(payload.medicamentoId),
        clienteId: payload.clienteId,
      }),
    onSuccess: async () => {
      await refreshAll()
    },
  })
  const deleteMascotaMutation = useMutation({
    mutationFn: deleteMascota,
    onSuccess: async () => {
      await refreshAll()
    },
  })

  const detalleColumns = useMemo(
    () => [
      { key: 'mascotaNombre', header: 'Mascota' },
      { key: 'raza', header: 'Raza' },
      { key: 'clienteNombreCompleto', header: 'Cliente' },
      { key: 'medicamentoNombre', header: 'Medicamento' },
      { key: 'medicamentoDosis', header: 'Dosis' },
      {
        key: 'estadoAuditoria',
        header: 'Estado',
        render: (row: AuditoriaDetalle) => (
          <span
            className={`rounded-full px-2 py-1 text-xs font-semibold ${
              row.estadoAuditoria === 'CONSISTENTE'
                ? 'bg-emerald-100 text-emerald-700'
                : 'bg-red-100 text-red-700'
            }`}
          >
            {row.estadoAuditoria}
          </span>
        ),
      },
    ],
    [],
  )

  const resumenClienteRows = useMemo(() => {
    if (!data) {
      return []
    }

    return Object.entries(data.resumenPorCliente).map(([cedula, value]) => ({
      cedula,
      nombre: value.clienteNombreCompleto,
      totalMascotas: value.totalMascotas,
    }))
  }, [data])

  const resumenMedicamentoRows = useMemo(() => {
    if (!data) {
      return []
    }

    return Object.entries(data.resumenPorMedicamento).map(([id, value]) => ({
      medicamentoId: id,
      medicamentoNombre: value.medicamentoNombre,
      totalMascotas: value.totalMascotas,
    }))
  }, [data])

  return (
    <main className="min-h-screen bg-slate-50 px-4 py-8 md:px-8">
      {toastMessage && (
        <div className="fixed right-4 top-4 z-50 rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-lg">
          {toastMessage}
        </div>
      )}
      <div className="mx-auto max-w-7xl space-y-6">
        <header className="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-slate-200 bg-white p-4">
          <div>
            <h1 className="text-2xl font-bold text-slate-900">PETS S.A. Dashboard</h1>
            <p className="text-sm text-slate-600">
              Relación entre mascotas y medicamentos consumidos
            </p>
          </div>
          <button
            className="rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white disabled:opacity-60"
            disabled={isFetching}
            onClick={() => refetchAuditoria()}
            type="button"
          >
            {isFetching ? 'Actualizando...' : 'Actualizar'}
          </button>
        </header>

        <section className="grid gap-6 lg:grid-cols-3">
          <article
            className={`space-y-3 rounded-lg border bg-white p-4 transition-shadow ${
              highlightedSection === 'cliente'
                ? 'border-slate-400 shadow-lg'
                : 'border-slate-200'
            }`}
            ref={clienteUpdateRef}
          >
            <h2 className="text-base font-semibold text-slate-900">Crear cliente</h2>
            <form
              className="space-y-2"
              onSubmit={(event) => {
                event.preventDefault()
                createClienteMutation.mutate(clienteForm)
              }}
            >
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setClienteForm((current) => ({ ...current, cedula: event.target.value }))} placeholder="Cédula" required value={clienteForm.cedula} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setClienteForm((current) => ({ ...current, nombres: event.target.value }))} placeholder="Nombres" required value={clienteForm.nombres} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setClienteForm((current) => ({ ...current, apellidos: event.target.value }))} placeholder="Apellidos" required value={clienteForm.apellidos} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setClienteForm((current) => ({ ...current, direccion: event.target.value }))} placeholder="Dirección" required value={clienteForm.direccion} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setClienteForm((current) => ({ ...current, telefono: event.target.value }))} placeholder="Teléfono" required value={clienteForm.telefono} />
              <button className="w-full rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white disabled:opacity-60" disabled={createClienteMutation.isPending} type="submit">Guardar cliente</button>
            </form>
          </article>

          <article
            className={`space-y-3 rounded-lg border bg-white p-4 transition-shadow ${
              highlightedSection === 'medicamento'
                ? 'border-slate-400 shadow-lg'
                : 'border-slate-200'
            }`}
            ref={medicamentoUpdateRef}
          >
            <h2 className="text-base font-semibold text-slate-900">Crear medicamento</h2>
            <form
              className="space-y-2"
              onSubmit={(event) => {
                event.preventDefault()
                createMedicamentoMutation.mutate(medicamentoForm)
              }}
            >
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMedicamentoForm((current) => ({ ...current, nombre: event.target.value }))} placeholder="Nombre" required value={medicamentoForm.nombre} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMedicamentoForm((current) => ({ ...current, descripcion: event.target.value }))} placeholder="Descripción" required value={medicamentoForm.descripcion} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMedicamentoForm((current) => ({ ...current, dosis: event.target.value }))} placeholder="Dosis" required value={medicamentoForm.dosis} />
              <button className="w-full rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white disabled:opacity-60" disabled={createMedicamentoMutation.isPending} type="submit">Guardar medicamento</button>
            </form>
          </article>

          <article
            className={`space-y-3 rounded-lg border bg-white p-4 transition-shadow ${
              highlightedSection === 'mascota'
                ? 'border-slate-400 shadow-lg'
                : 'border-slate-200'
            }`}
            ref={mascotaUpdateRef}
          >
            <h2 className="text-base font-semibold text-slate-900">Crear mascota</h2>
            <form
              className="space-y-2"
              onSubmit={(event) => {
                event.preventDefault()
                createMascotaMutation.mutate({
                  nombre: mascotaForm.nombre,
                  raza: mascotaForm.raza,
                  edad: Number(mascotaForm.edad),
                  peso: Number(mascotaForm.peso),
                  medicamentoId: Number(mascotaForm.medicamentoId),
                  clienteId: mascotaForm.clienteId,
                })
              }}
            >
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMascotaForm((current) => ({ ...current, nombre: event.target.value }))} placeholder="Nombre" required value={mascotaForm.nombre} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMascotaForm((current) => ({ ...current, raza: event.target.value }))} placeholder="Raza" required value={mascotaForm.raza} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" min={0} onChange={(event) => setMascotaForm((current) => ({ ...current, edad: event.target.value }))} placeholder="Edad" required type="number" value={mascotaForm.edad} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" min={0.1} onChange={(event) => setMascotaForm((current) => ({ ...current, peso: event.target.value }))} placeholder="Peso" required step="0.01" type="number" value={mascotaForm.peso} />
              <select className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMascotaForm((current) => ({ ...current, clienteId: event.target.value }))} required value={mascotaForm.clienteId}>
                <option value="">Seleccione cliente</option>
                {clientes.map((cliente) => (
                  <option key={cliente.cedula} value={cliente.cedula}>{cliente.cedula} - {cliente.nombres} {cliente.apellidos}</option>
                ))}
              </select>
              <select className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" onChange={(event) => setMascotaForm((current) => ({ ...current, medicamentoId: event.target.value }))} required value={mascotaForm.medicamentoId}>
                <option value="">Seleccione medicamento</option>
                {medicamentos.map((medicamento) => (
                  <option key={medicamento.id} value={medicamento.id}>{medicamento.id} - {medicamento.nombre}</option>
                ))}
              </select>
              <button className="w-full rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white disabled:opacity-60" disabled={createMascotaMutation.isPending} type="submit">Guardar mascota</button>
            </form>
          </article>
        </section>

        <section className="grid gap-6 lg:grid-cols-3">
          <article className="space-y-3 rounded-lg border border-slate-200 bg-white p-4">
            <h2 className="text-base font-semibold text-slate-900">Actualizar cliente</h2>
            <form className="space-y-2" onSubmit={(event) => { event.preventDefault(); updateClienteMutation.mutate(clienteUpdateForm) }}>
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Cédula" required value={clienteUpdateForm.cedula} onChange={(event) => setClienteUpdateForm((current) => ({ ...current, cedula: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Nombres" required value={clienteUpdateForm.nombres} onChange={(event) => setClienteUpdateForm((current) => ({ ...current, nombres: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Apellidos" required value={clienteUpdateForm.apellidos} onChange={(event) => setClienteUpdateForm((current) => ({ ...current, apellidos: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Dirección" required value={clienteUpdateForm.direccion} onChange={(event) => setClienteUpdateForm((current) => ({ ...current, direccion: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Teléfono" required value={clienteUpdateForm.telefono} onChange={(event) => setClienteUpdateForm((current) => ({ ...current, telefono: event.target.value }))} />
              <button className="w-full rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white" type="submit">Actualizar cliente</button>
            </form>
          </article>
          <article className="space-y-3 rounded-lg border border-slate-200 bg-white p-4">
            <h2 className="text-base font-semibold text-slate-900">Actualizar medicamento</h2>
            <form className="space-y-2" onSubmit={(event) => { event.preventDefault(); updateMedicamentoMutation.mutate(medicamentoUpdateForm) }}>
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="ID" required type="number" value={medicamentoUpdateForm.id} onChange={(event) => setMedicamentoUpdateForm((current) => ({ ...current, id: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Nombre" required value={medicamentoUpdateForm.nombre} onChange={(event) => setMedicamentoUpdateForm((current) => ({ ...current, nombre: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Descripción" required value={medicamentoUpdateForm.descripcion} onChange={(event) => setMedicamentoUpdateForm((current) => ({ ...current, descripcion: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Dosis" required value={medicamentoUpdateForm.dosis} onChange={(event) => setMedicamentoUpdateForm((current) => ({ ...current, dosis: event.target.value }))} />
              <button className="w-full rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white" type="submit">Actualizar medicamento</button>
            </form>
          </article>
          <article className="space-y-3 rounded-lg border border-slate-200 bg-white p-4">
            <h2 className="text-base font-semibold text-slate-900">Actualizar mascota</h2>
            <form className="space-y-2" onSubmit={(event) => { event.preventDefault(); updateMascotaMutation.mutate(mascotaUpdateForm) }}>
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="ID mascota" required value={mascotaUpdateForm.id} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, id: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Nombre" required value={mascotaUpdateForm.nombre} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, nombre: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Raza" required value={mascotaUpdateForm.raza} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, raza: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Edad" required type="number" value={mascotaUpdateForm.edad} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, edad: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Peso" required type="number" step="0.01" value={mascotaUpdateForm.peso} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, peso: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="ID medicamento" required type="number" value={mascotaUpdateForm.medicamentoId} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, medicamentoId: event.target.value }))} />
              <input className="w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Cédula cliente" required value={mascotaUpdateForm.clienteId} onChange={(event) => setMascotaUpdateForm((current) => ({ ...current, clienteId: event.target.value }))} />
              <button className="w-full rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white" type="submit">Actualizar mascota</button>
            </form>
          </article>
        </section>

        <section className="grid gap-6 lg:grid-cols-3">
          <div className="space-y-3">
            <h2 className="text-lg font-semibold text-slate-900">Clientes</h2>
            <DataTable
              columns={[
                { key: 'cedula', header: 'Cédula' },
                { key: 'nombres', header: 'Nombres' },
                { key: 'apellidos', header: 'Apellidos' },
                {
                  key: 'acciones',
                  header: 'Acciones',
                  render: (row) => (
                    <div className="flex gap-2">
                      <button
                        className="rounded bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-700"
                        onClick={() =>
                          {
                            setClienteUpdateForm({
                              cedula: `${row.cedula}`,
                              nombres: `${row.nombres}`,
                              apellidos: `${row.apellidos}`,
                              direccion: `${row.direccion}`,
                              telefono: `${row.telefono}`,
                            })
                            setToastMessage('Formulario de cliente cargado para edición')
                            setHighlightedSection('cliente')
                            scrollToUpdateSection('cliente')
                          }
                        }
                        type="button"
                      >
                        Editar
                      </button>
                      <button className="rounded bg-red-100 px-2 py-1 text-xs font-semibold text-red-700" onClick={() => deleteClienteMutation.mutate(`${row.cedula}`)} type="button">Eliminar</button>
                    </div>
                  ),
                },
              ]}
              data={clientes}
              emptyMessage="No hay clientes registrados."
            />
          </div>
          <div className="space-y-3">
            <h2 className="text-lg font-semibold text-slate-900">Medicamentos</h2>
            <DataTable
              columns={[
                { key: 'id', header: 'ID' },
                { key: 'nombre', header: 'Nombre' },
                { key: 'dosis', header: 'Dosis' },
                {
                  key: 'acciones',
                  header: 'Acciones',
                  render: (row) => (
                    <div className="flex gap-2">
                      <button
                        className="rounded bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-700"
                        onClick={() =>
                          {
                            setMedicamentoUpdateForm({
                              id: `${row.id}`,
                              nombre: `${row.nombre}`,
                              descripcion: `${row.descripcion}`,
                              dosis: `${row.dosis}`,
                            })
                            setToastMessage('Formulario de medicamento cargado para edición')
                            setHighlightedSection('medicamento')
                            scrollToUpdateSection('medicamento')
                          }
                        }
                        type="button"
                      >
                        Editar
                      </button>
                      <button className="rounded bg-red-100 px-2 py-1 text-xs font-semibold text-red-700" onClick={() => deleteMedicamentoMutation.mutate(Number(row.id))} type="button">Eliminar</button>
                    </div>
                  ),
                },
              ]}
              data={medicamentos}
              emptyMessage="No hay medicamentos registrados."
            />
          </div>
          <div className="space-y-3">
            <h2 className="text-lg font-semibold text-slate-900">Mascotas</h2>
            <DataTable
              columns={[
                { key: 'id', header: 'ID' },
                { key: 'nombre', header: 'Nombre' },
                { key: 'raza', header: 'Raza' },
                { key: 'clienteId', header: 'Cliente' },
                {
                  key: 'acciones',
                  header: 'Acciones',
                  render: (row) => (
                    <div className="flex gap-2">
                      <button
                        className="rounded bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-700"
                        onClick={() =>
                          {
                            setMascotaUpdateForm({
                              id: `${row.id}`,
                              nombre: `${row.nombre}`,
                              raza: `${row.raza}`,
                              edad: `${row.edad}`,
                              peso: `${row.peso}`,
                              medicamentoId: `${row.medicamentoId}`,
                              clienteId: `${row.clienteId}`,
                            })
                            setToastMessage('Formulario de mascota cargado para edición')
                            setHighlightedSection('mascota')
                            scrollToUpdateSection('mascota')
                          }
                        }
                        type="button"
                      >
                        Editar
                      </button>
                      <button className="rounded bg-red-100 px-2 py-1 text-xs font-semibold text-red-700" onClick={() => deleteMascotaMutation.mutate(`${row.id}`)} type="button">Eliminar</button>
                    </div>
                  ),
                },
              ]}
              data={mascotas}
              emptyMessage="No hay mascotas registradas."
            />
          </div>
        </section>

        {isLoading && (
          <div className="rounded-lg border border-slate-200 bg-white p-6 text-sm text-slate-500">
            Cargando reporte de auditoría...
          </div>
        )}

        {isError && (
          <div className="rounded-lg border border-red-200 bg-red-50 p-6 text-sm text-red-700">
            {(error as Error).message}
          </div>
        )}

        {data && (
          <>
            <section className="grid gap-4 md:grid-cols-3">
              <article className="rounded-lg border border-slate-200 bg-white p-4">
                <p className="text-xs font-medium uppercase text-slate-500">Registros</p>
                <p className="mt-2 text-2xl font-bold text-slate-900">{data.totalRegistros}</p>
              </article>
              <article className="rounded-lg border border-slate-200 bg-white p-4">
                <p className="text-xs font-medium uppercase text-slate-500">Inconsistencias</p>
                <p className="mt-2 text-2xl font-bold text-slate-900">{data.totalInconsistencias}</p>
              </article>
              <article className="rounded-lg border border-slate-200 bg-white p-4">
                <p className="text-xs font-medium uppercase text-slate-500">Generado en</p>
                <p className="mt-2 text-sm font-semibold text-slate-900">{new Date(data.generadoEn).toLocaleString()}</p>
              </article>
            </section>

            <section className="space-y-3">
              <h2 className="text-lg font-semibold text-slate-900">Detalle de auditoría</h2>
              <DataTable
                columns={detalleColumns}
                data={data.detalles}
                emptyMessage="No hay registros de auditoría para mostrar."
              />
            </section>

            <section className="grid gap-6 lg:grid-cols-2">
              <div className="space-y-3">
                <h2 className="text-lg font-semibold text-slate-900">Resumen por cliente</h2>
                <DataTable
                  columns={[
                    { key: 'cedula', header: 'Cédula' },
                    { key: 'nombre', header: 'Cliente' },
                    { key: 'totalMascotas', header: 'Mascotas' },
                  ]}
                  data={resumenClienteRows}
                  emptyMessage="Sin datos de clientes."
                />
              </div>
              <div className="space-y-3">
                <h2 className="text-lg font-semibold text-slate-900">Resumen por medicamento</h2>
                <DataTable
                  columns={[
                    { key: 'medicamentoId', header: 'ID' },
                    { key: 'medicamentoNombre', header: 'Medicamento' },
                    { key: 'totalMascotas', header: 'Mascotas' },
                  ]}
                  data={resumenMedicamentoRows}
                  emptyMessage="Sin datos de medicamentos."
                />
              </div>
            </section>
          </>
        )}
      </div>
    </main>
  )
}

export default App
