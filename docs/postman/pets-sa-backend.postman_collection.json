          "name": "Crear Cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cedula\": \"123456789\",\n  \"nombres\": \"Juan\",\n  \"apellidos\": \"Perez\",\n  \"direccion\": \"Calle 10 #20-30\",\n  \"telefono\": \"3001234567\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes"
              ]
            }
          }
