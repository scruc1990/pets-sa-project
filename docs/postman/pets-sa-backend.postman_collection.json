            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Juan Carlos\",\n  \"apellidos\": \"Perez Gomez\",\n  \"direccion\": \"Av. Siempre Viva 742\",\n  \"telefono\": \"3017654321\"\n}"
